.goods-card {
  width: 340rpx;
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.cover {
  width: 100%;
  height: 260rpx;
}

.info {
  padding: 16rpx;
}

.title {
  font-weight: 500;
  display: block;
  margin-bottom: 10rpx;
}

.price {
  color: #f56c6c;
  font-weight: bold;
}

.swap-tag {
  color: #36c66f;
  border: 1rpx solid #36c66f;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
}

.campus {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}
